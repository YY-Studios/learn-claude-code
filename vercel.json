{
  "buildCommand": "npm run build",
  "outputDirectory": ".vitepress/dist",
  "cleanUrls": true,
  "redirects": [
    { "source": "/02-context/rules.html", "destination": "/04-claude-control/rules", "permanent": true },
    { "source": "/en/02-context/rules.html", "destination": "/en/04-claude-control/rules", "permanent": true },
    { "source": "/ja/02-context/rules.html", "destination": "/ja/04-claude-control/rules", "permanent": true },
    { "source": "/04-agents/hooks.html", "destination": "/04-claude-control/hooks", "permanent": true },
    { "source": "/en/04-agents/hooks.html", "destination": "/en/04-claude-control/hooks", "permanent": true },
    { "source": "/ja/04-agents/hooks.html", "destination": "/ja/04-claude-control/hooks", "permanent": true },
    { "source": "/04-agents/custom-commands.html", "destination": "/05-claude-extend/custom-commands", "permanent": true },
    { "source": "/en/04-agents/custom-commands.html", "destination": "/en/05-claude-extend/custom-commands", "permanent": true },
    { "source": "/ja/04-agents/custom-commands.html", "destination": "/ja/05-claude-extend/custom-commands", "permanent": true },
    { "source": "/04-agents/mcp.html", "destination": "/05-claude-extend/mcp", "permanent": true },
    { "source": "/en/04-agents/mcp.html", "destination": "/en/05-claude-extend/mcp", "permanent": true },
    { "source": "/ja/04-agents/mcp.html", "destination": "/ja/05-claude-extend/mcp", "permanent": true },
    { "source": "/04-agents/skills.html", "destination": "/05-claude-extend/skills", "permanent": true },
    { "source": "/en/04-agents/skills.html", "destination": "/en/05-claude-extend/skills", "permanent": true },
    { "source": "/ja/04-agents/skills.html", "destination": "/ja/05-claude-extend/skills", "permanent": true },
    { "source": "/04-agents/subagents.html", "destination": "/07-claude-structure/subagents", "permanent": true },
    { "source": "/en/04-agents/subagents.html", "destination": "/en/07-claude-structure/subagents", "permanent": true },
    { "source": "/ja/04-agents/subagents.html", "destination": "/ja/07-claude-structure/subagents", "permanent": true },
    { "source": "/04-agents/wat-overview.html", "destination": "/07-claude-structure/wat-overview", "permanent": true },
    { "source": "/en/04-agents/wat-overview.html", "destination": "/en/07-claude-structure/wat-overview", "permanent": true },
    { "source": "/ja/04-agents/wat-overview.html", "destination": "/ja/07-claude-structure/wat-overview", "permanent": true },
    { "source": "/05-resources/:path*", "destination": "/06-resources/:path*", "permanent": true },
    { "source": "/en/5-resources/:path*", "destination": "/en/06-resources/:path*", "permanent": true },
    { "source": "/06-tips/:path*", "destination": "/08-tips/:path*", "permanent": true },
    { "source": "/en/06-tips/:path*", "destination": "/en/08-tips/:path*", "permanent": true },
    { "source": "/ja/06-tips/:path*", "destination": "/ja/08-tips/:path*", "permanent": true },
    { "source": "/07-supabase/:path*", "destination": "/09-supabase/:path*", "permanent": true },
    { "source": "/en/07-supabase/:path*", "destination": "/en/09-supabase/:path*", "permanent": true },
    { "source": "/ja/07-supabase/:path*", "destination": "/ja/09-supabase/:path*", "permanent": true },
    { "source": "/06-supabase/:path*", "destination": "/09-supabase/:path*", "permanent": true },
    { "source": "/en/06-supabase/:path*", "destination": "/en/09-supabase/:path*", "permanent": true },
    { "source": "/ja/06-supabase/:path*", "destination": "/ja/09-supabase/:path*", "permanent": true },
    { "source": "/08-devlog/:path*", "destination": "/10-devlog/:path*", "permanent": true },
    { "source": "/en/08-devlog/:path*", "destination": "/en/10-devlog/:path*", "permanent": true },
    { "source": "/ja/08-devlog/:path*", "destination": "/ja/10-devlog/:path*", "permanent": true }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    },
    {
      "source": "/assets/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
